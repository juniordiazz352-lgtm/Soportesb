import discord
from discord.ui import View, button

class FormReviewView(View):
    def __init__(self, user_id):
        super().__init__(timeout=None)
        self.user_id = user_id

    @button(label="✅ Aprobar", style=discord.ButtonStyle.success, emoji="🔥")
async def approve(self, interaction, button):

    user = await interaction.client.fetch_user(self.user_id)

    embed = discord.Embed(
        title="✅ Formulario Aprobado",
        description="Tu solicitud fue aceptada",
        color=discord.Color.green()
    )

    try:
        await user.send(embed=embed)
    except:
        pass

    await interaction.response.send_message("🔥 Aprobado", ephemeral=True)
    self.disable_all_items()
    await interaction.message.edit(view=self)


@button(label="❌ Rechazar", style=discord.ButtonStyle.danger, emoji="💀")
async def reject(self, interaction, button):

    user = await interaction.client.fetch_user(self.user_id)

    embed = discord.Embed(
        title="❌ Formulario Rechazado",
        description="Tu solicitud fue rechazada",
        color=discord.Color.red()
    )

    try:
        await user.send(embed=embed)
    except:
        pass

    await interaction.response.send_message("💀 Rechazado", ephemeral=True)
    self.disable_all_items()
    await interaction.message.edit(view=self)
